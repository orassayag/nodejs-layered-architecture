{
  "name": "nodejs-layered-architecture",
  "version": "1.0.0",
  "description": "A demonstration Node.js application showcasing clean layered architecture pattern with Express.js and MongoDB for building maintainable RESTful APIs",
  "main": "src/server.js",
  "author": "Or Assayag <orassayag@gmail.com>",
  "license": "MIT",
  "keywords": [
    "nodejs",
    "express",
    "mongodb",
    "layered-architecture",
    "clean-architecture",
    "rest-api",
    "separation-of-concerns",
    "dependency-injection",
    "mvc",
    "repository-pattern",
    "service-layer"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/orassayag/nodejs-layered-architecture.git"
  },
  "bugs": {
    "url": "https://github.com/orassayag/nodejs-layered-architecture/issues"
  },
  "homepage": "https://github.com/orassayag/nodejs-layered-architecture#readme",
  "scripts": {
    "start": "node src/server.js",
    "start:prod": "node -r dotenv/config src/server.js",
    "watch": "nodemon src/server.js",
    "watch:prod": "nodemon -r dotenv/config src/server.js",
    "test:unit": "mocha test/unit",
    "test:component": "mocha --exit test/component",
    "test": "npm-run-all --parallel test:*",
    "lint": "eslint 'src/**/*.js'"
  },
  "husky": {
    "hooks": {
      "pre-commit": "lint-staged"
    }
  },
  "lint-staged": {
    "src/**/*.{js,md}": "eslint --fix",
    "src/**/*.{json}": "prettier --write"
  },
  "dependencies": {
    "@hapi/joi": "17.1.0",
    "crossenv": "0.0.2-security",
    "dotenv": "8.2.0",
    "express": "4.17.1",
    "hbs": "4.1.0",
    "mongodb": "3.3.4",
    "why-is-node-running": "^2.1.0"
  },
  "devDependencies": {
    "eslint": "6.8.0",
    "eslint-config-airbnb-base": "14.0.0",
    "eslint-config-prettier": "6.10.0",
    "eslint-plugin-hbs": "1.0.0",
    "eslint-plugin-import": "2.20.1",
    "eslint-plugin-prettier": "3.1.2",
    "husky": "4.2.3",
    "lint-staged": "10.0.8",
    "mocha": "6.2.2",
    "nodemon": "1.19.4",
    "npm-run-all": "4.1.5",
    "prettier": "1.19.1",
    "supertest": "4.0.2"
  }
}
